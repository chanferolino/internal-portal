generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────

enum Mood {
  EXCITED
  HAPPY
  NEUTRAL
  TIRED
  STRESSED
}

enum LeaveType {
  VACATION
  SICK
  PERSONAL
  BEREAVEMENT
  MATERNITY
  PATERNITY
}

enum LeaveCategory {
  PLANNED
  UNPLANNED
  EMERGENCY
}

enum FilingType {
  FULL_DAY
  HALF_DAY
  UNDERTIME
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum OutageType {
  INTERNET
  POWER
}

enum TicketCategory {
  HR
  FINANCE
  IT
}

enum TicketSubCategory {
  PERIPHERALS
  PERMISSIONS
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ─── Models ──────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  image     String?
  timezone  String   @default("Asia/Manila")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  accounts     Account[]
  sessions     Session[]
  timeEntries  TimeEntry[]
  shiftReports ShiftReport[]
  leaveRequests LeaveRequest[]
  outageReports OutageReport[]
  tickets      Ticket[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model TimeEntry {
  id       String    @id @default(cuid())
  userId   String    @map("user_id")
  clockIn  DateTime  @map("clock_in")
  clockOut DateTime? @map("clock_out")
  timezone String    @default("Asia/Manila")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("time_entries")
}

model ShiftReport {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  mood              Mood
  accomplishments   String
  challenges        String
  managementSupport String?  @map("management_support")
  date              DateTime @db.Date
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("shift_reports")
}

model LeaveRequest {
  id          String        @id @default(cuid())
  userId      String        @map("user_id")
  startDate   DateTime      @map("start_date") @db.Date
  endDate     DateTime      @map("end_date") @db.Date
  leaveType   LeaveType     @map("leave_type")
  category    LeaveCategory
  filingType  FilingType    @map("filing_type")
  reason      String
  attachments String[]
  status      LeaveStatus   @default(PENDING)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("leave_requests")
}

model OutageReport {
  id        String     @id @default(cuid())
  userId    String     @map("user_id")
  type      OutageType
  cause     String
  address   String
  city      String
  startTime DateTime   @map("start_time")
  endTime   DateTime?  @map("end_time")
  startDate DateTime   @map("start_date") @db.Date
  endDate   DateTime?  @map("end_date") @db.Date
  details   String?
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("outage_reports")
}

model Ticket {
  id          String             @id @default(cuid())
  userId      String             @map("user_id")
  category    TicketCategory
  subCategory TicketSubCategory? @map("sub_category")
  subject     String
  description String
  status      TicketStatus       @default(OPEN)
  priority    TicketPriority     @default(MEDIUM)
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tickets")
}
